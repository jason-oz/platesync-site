{# ──── Pricing FAQ ──── #}
<section class="bg-white">
  <div class="max-w-3xl mx-auto px-6 py-20 md:py-24">
    <div class="text-center mb-12">
      <p class="font-mono text-xs font-medium uppercase tracking-widest text-emerald-600 mb-2">Questions</p>
      <h2 class="text-3xl font-bold text-neutral-900">Pricing FAQ</h2>
    </div>
    <div class="space-y-6">
      {% set pricingFaqs = [
        { q: "Is PlateSync really free?", a: "Yes. The Free plan gives you unlimited family profiles, 20 recipes, 5 AI imports per month, full meal planning, pantry tracking, shopping lists, cooking mode, and leftover tracking — forever, no credit card required." },
        { q: "What do I get with the Family Plan?", a: "Everything in Free, plus household sharing for up to 5 users, unlimited recipes, unlimited AI recipe imports, and priority support." },
        { q: "Is there a free trial?", a: "Yes. Try the Family Plan free for 30 days — no credit card required. If you don't upgrade, you'll automatically move to the Free plan. No surprises." },
        { q: "Can I switch plans?", a: "Yes. Upgrade, downgrade, or cancel at any time. If you downgrade from Family to Free, you keep access until the end of your billing period." },
        { q: "Do I save money with annual billing?", a: "Yes. Annual billing is $69.99 AUD per year — that's roughly $5.83 per month, saving you over 27% compared to monthly billing." },
        { q: "What happens to my recipes if I downgrade?", a: "Your recipes stay. If you have more than 20 recipes on the Free plan, you can still view and cook them — you just can't add new ones until you're under the limit or upgrade again." }
      ] %}
      {% for faq in pricingFaqs %}
      <div class="border-b border-neutral-200 pb-6">
        <h3 class="text-base font-semibold text-neutral-900">{{ faq.q }}</h3>
        <p class="mt-2 text-sm text-neutral-600 leading-relaxed">{{ faq.a }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

